<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/favorites_grid"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:useDefaultMargins="true"
    android:columnCount="3">

    <Button
        android:id="@+id/main_6_6_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:onClick="onClickBoardSize"
        android:tag="6 6"
        android:text="@string/board_6_6"
        android:textSize="34sp" />

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="16dp" />

    <Button
        android:id="@+id/main_4_4_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:onClick="onClickBoardSize"
        android:tag="4 4"
        android:text="@string/board_4_4"
        android:textSize="34sp" />

    <Button
        android:id="@+id/main_4_5_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:onClick="onClickBoardSize"
        android:tag="4 5"
        android:text="@string/board_4_5"
        android:textSize="34sp" />

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="16dp" />

    <Button
        android:id="@+id/main_5_2_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:onClick="onClickBoardSize"
        android:tag="5 2"
        android:text="@string/board_5_2"
        android:textSize="34sp" />

</GridLayout>